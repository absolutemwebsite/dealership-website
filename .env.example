# Absolute Motor Cars — Environment Variables
# Copy this to .env and fill in values before deploying.

# --- Authentication ---
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- Login Credentials ---
OWNER_USERNAME=owner
OWNER_PASSWORD=changeme
STAFF_USERNAME=staff
STAFF_PASSWORD=changeme

# --- CRM Data (GitHub-as-database) ---
# Create a PRIVATE GitHub repo for CRM data. Add a data.json file:
#   { "crmVehicles": [], "soldRecords": [] }
# Create a fine-grained PAT with Contents: Read & Write on that repo only.
GITHUB_TOKEN=github_pat_xxxx
GITHUB_OWNER=absolutemwebsite
GITHUB_REPO=dealership-crm-data
GITHUB_BRANCH=main
DATA_PATH=data.json

# --- Storage Paths ---
DATA_DIR=/app/storage/data
UPLOADS_DIR=/app/storage/uploads

# --- Email (Resend) ---
# Sign up at https://resend.com, get API key from dashboard
RESEND_API_KEY=re_xxxx
NOTIFY_EMAIL=owner@dealership.com
FROM_EMAIL=onboarding@resend.dev

# --- Optional ---
PORT=3000
PUBLIC_URL=https://your-app.railway.app
